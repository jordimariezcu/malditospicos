---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  updated?: string;
  labels?: string[];
  section: string;
  image?: string;
}

const { title, description, date, updated, labels = [], section, image } = Astro.props;

const sectionLabels: Record<string, string> = {
  gomas: 'Gomas',
  maderas: 'Maderas',
  palas: 'Configuraciones',
  tecnica: 'Técnica',
  jugadores: 'Jugadores',
  materiales: 'Materiales',
  recursos: 'Recursos',
  guias: 'Guías',
};

const sectionPaths: Record<string, string> = {
  gomas: '/gomas/',
  maderas: '/maderas/',
  palas: '/palas/',
  tecnica: '/tecnica/',
  jugadores: '/jugadores/',
  materiales: '/materiales/',
  recursos: '/recursos/',
  guias: '/guias/',
};

const sectionLabel = sectionLabels[section] || section;
const sectionPath = sectionPaths[section] || '/';

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('es-ES', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}

// Schema Article
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: date,
  dateModified: updated || date,
  author: {
    '@type': 'Organization',
    name: 'Malditos Picos',
    url: 'https://www.malditospicos.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Malditos Picos',
    url: 'https://www.malditospicos.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.malditospicos.com/favicon.ico',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.href,
  },
  ...(image && { image: new URL(image, Astro.site).href }),
};

// BreadcrumbList Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://www.malditospicos.com/' },
    { '@type': 'ListItem', position: 2, name: sectionLabel, item: `https://www.malditospicos.com${sectionPath}` },
    { '@type': 'ListItem', position: 3, name: title, item: Astro.url.href },
  ],
};
---

<Base title={title} description={description} type="article" schema={schema}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <div class="container-narrow">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Inicio</a>
      <span class="breadcrumb-sep">›</span>
      <a href={sectionPath}>{sectionLabel}</a>
      <span class="breadcrumb-sep">›</span>
      <span>{title}</span>
    </nav>

    <header class="post-header">
      <div class="post-meta">
        <a href={sectionPath} class="label-tag">{sectionLabel}</a>
        <time datetime={date}>{formatDate(date)}</time>
        {updated && updated !== date && (
          <time datetime={updated} style="color: var(--color-text-muted); font-size: 0.78rem;">
            Actualizado: {formatDate(updated)}
          </time>
        )}
      </div>
      <h1>{title}</h1>
    </header>

    <article class="prose">
      <slot />
    </article>

    <div class="related">
      <p style="font-size:0.85rem; color: var(--color-text-muted);">
        ¿Te ha sido útil? Explora más sobre <a href={sectionPath}>{sectionLabel}</a>.
      </p>
    </div>
  </div>
</Base>
