---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
const { title, description, image, type = 'website', pubDate, updatedDate, category } = Astro.props;
const siteTitle = 'Malditos Picos';
const siteDesc = 'Todo sobre el tenis de mesa: gomas, maderas, palas y técnica.';
const fullTitle = title ? `${title} · ${siteTitle}` : siteTitle;
const metaDesc = description || siteDesc;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const defaultImage = new URL('/og-default.svg', Astro.site).href;
const ogImage = image || defaultImage;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="alternate" type="application/rss+xml" title="Malditos Picos" href="/rss.xml" />
  <title>{fullTitle}</title>
  <meta name="description" content={metaDesc} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteTitle} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Article specific -->
  {type === 'article' && pubDate && <meta property="article:published_time" content={pubDate} />}
  {type === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate} />}
  {type === 'article' && category && <meta property="article:section" content={category} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={metaDesc} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Sitemap & RSS -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Umami Analytics -->
  <script defer src="https://umami-production-c3fa.up.railway.app/script.js" data-website-id="afad68a9-3c93-4950-be19-5acc1a07d0f8"></script>

  <!-- Schema: WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": siteTitle,
    "url": "https://www.malditospicos.com",
    "description": siteDesc,
    "inLanguage": "es"
  })} />

  <slot name="head" />
</head>
<body>
  <header class="site-header" data-pagefind-ignore>
    <div class="container header-inner">
      <a href="/" class="logo">
        <span class="logo-main">Malditos</span>
        <span class="logo-accent">Picos</span>
      </a>
      <nav class="main-nav">
        <a href="/gomas/">Gomas</a>
        <a href="/maderas/">Maderas</a>
        <a href="/palas/">Palas</a>
        <a href="/tecnica/">Técnica</a>
        <a href="/jugadores/">Jugadores</a>
        <a href="/guias/">Guías</a>
      </nav>
      <div class="header-actions">
        <button class="search-btn" id="searchOpen" aria-label="Buscar en Malditos Picos">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        <button class="nav-toggle" aria-label="Menú" id="navToggle">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer" data-pagefind-ignore>
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo"><span class="logo-main">Malditos</span><span class="logo-accent">Picos</span></a>
        <p>Todo sobre el tenis de mesa</p>
      </div>
      <nav class="footer-nav">
        <a href="/gomas/">Gomas</a>
        <a href="/maderas/">Maderas</a>
        <a href="/palas/">Palas</a>
        <a href="/tecnica/">Técnica</a>
        <a href="/jugadores/">Jugadores</a>
        <a href="/guias/">Guías</a>
      </nav>
      <p class="footer-copy">© {new Date().getFullYear()} Malditos Picos · <a href="/sobre-nosotros/">Sobre nosotros</a> · <a href="/privacidad/">Privacidad</a> · <a href="/aviso-legal/">Aviso legal</a> · <a href="mailto:malditospicos@gmail.com">Contacto</a></p>
    </div>
  </footer>

  <!-- Search modal -->
  <dialog class="search-modal" id="searchModal" aria-label="Buscar">
    <div class="search-modal-inner">
      <div class="search-modal-header">
        <span class="search-modal-label">Buscar en Malditos Picos</span>
        <button class="search-modal-close" id="searchClose" aria-label="Cerrar búsqueda">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="pagefind-search"></div>
      <p class="search-hint">También puedes usar <kbd>Ctrl K</kbd> para abrir la búsqueda</p>
    </div>
  </dialog>

  <script>
    // Nav toggle
    const toggle = document.getElementById('navToggle');
    const nav = document.querySelector('.main-nav');
    toggle?.addEventListener('click', () => nav?.classList.toggle('open'));

    // Search modal
    const searchOpen = document.getElementById('searchOpen');
    const searchModal = document.getElementById('searchModal') as HTMLDialogElement | null;
    const searchClose = document.getElementById('searchClose');
    let pagefindLoaded = false;

    async function loadPagefind() {
      if (pagefindLoaded) return;
      pagefindLoaded = true;
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = () => {
        new (window as any).PagefindUI({
          element: '#pagefind-search',
          showImages: false,
          resetStyles: false,
          translations: {
            placeholder: 'Buscar artículos...',
            zero_results: 'Sin resultados para "[QUERY]"',
            searching: 'Buscando...',
          }
        });
      };
      document.head.appendChild(script);
    }

    function openSearch() {
      loadPagefind();
      searchModal?.showModal();
      setTimeout(() => {
        const input = searchModal?.querySelector('input') as HTMLInputElement | null;
        input?.focus();
      }, 150);
    }

    searchOpen?.addEventListener('click', openSearch);
    searchClose?.addEventListener('click', () => searchModal?.close());
    searchModal?.addEventListener('click', (e) => {
      if (e.target === searchModal) searchModal.close();
    });
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
    });
  </script>
  <Analytics />
</body>
</html>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--header-bg);
  border-bottom: 2px solid var(--accent-bright);
}
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  gap: 24px;
}
.logo {
  font-family: var(--font-display);
  font-size: 1.45rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  flex-shrink: 0;
}
.logo-main { color: #ffffff; }
.logo-accent { color: var(--accent-bright); margin-left: 5px; }
.main-nav {
  display: flex;
  gap: 2px;
  flex-wrap: wrap;
}
.main-nav a {
  font-family: var(--font-display);
  font-size: 0.92rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.75);
  padding: 6px 12px;
  border-radius: var(--radius);
  transition: all 0.15s;
}
.main-nav a:hover { color: #ffffff; background: rgba(255,255,255,0.1); }

.header-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}
.search-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: var(--radius);
  color: rgba(255,255,255,0.75);
  cursor: pointer;
  transition: all 0.15s;
}
.search-btn:hover { background: rgba(255,255,255,0.18); color: #fff; border-color: rgba(255,255,255,0.3); }

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}
.nav-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: #ffffff;
  border-radius: 2px;
  transition: 0.2s;
}
.site-footer {
  margin-top: 80px;
  background: var(--header-bg);
  border-top: 2px solid var(--accent-bright);
}
.footer-inner {
  padding: 48px 24px 32px;
  display: flex;
  flex-direction: column;
  gap: 24px;
  align-items: center;
  text-align: center;
}
.footer-brand p { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 4px; }
.footer-nav { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }
.footer-nav a { font-size: 0.82rem; font-family: var(--font-display); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(255,255,255,0.65); }
.footer-nav a:hover { color: #ffffff; }
.footer-copy { font-size: 0.8rem; color: rgba(255,255,255,0.4); }
.footer-copy a { color: rgba(255,255,255,0.65); }
.footer-copy a:hover { color: #fff; }

/* Search modal */
.search-modal {
  position: fixed;
  top: 80px;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 32px);
  max-width: 620px;
  max-height: calc(100vh - 110px);
  overflow-y: auto;
  border: 1px solid var(--border);
  border-radius: 8px;
  box-shadow: 0 24px 64px rgba(0,20,60,0.25);
  padding: 0;
  background: var(--bg);
  z-index: 200;
}
.search-modal::backdrop {
  background: rgba(0, 15, 40, 0.55);
  backdrop-filter: blur(3px);
}
.search-modal-inner {
  padding: 20px 24px 16px;
}
.search-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.search-modal-label {
  font-family: var(--font-display);
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
}
.search-modal-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.15s;
}
.search-modal-close:hover { background: var(--border); color: var(--text); }
.search-hint {
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 12px;
  text-align: center;
}
.search-hint kbd {
  font-family: var(--font-body);
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 1px 5px;
  font-size: 0.72rem;
}

@media (max-width: 768px) {
  .nav-toggle { display: flex; }
  .main-nav {
    display: none;
    position: absolute;
    top: 66px;
    left: 0;
    right: 0;
    background: var(--header-bg);
    border-bottom: 2px solid var(--accent-bright);
    padding: 16px 24px;
    flex-direction: column;
    gap: 4px;
  }
  .main-nav.open { display: flex; }
  .main-nav a { padding: 10px 12px; font-size: 1rem; }
  .search-modal { top: 70px; }
}
</style>
