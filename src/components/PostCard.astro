---
const { post, collection } = Astro.props;
const { title, description, pubDate, rating, image, tags } = post.data;
const tagsJson = JSON.stringify(tags ?? []);

const categoryLabels: Record<string, string> = {
  gomas: 'Gomas', maderas: 'Maderas', palas: 'Palas', tecnica: 'Técnica',
  guias: 'Guías', jugadores: 'Jugadores', materiales: 'Materiales', recursos: 'Recursos'
};

const catLabel = categoryLabels[collection] || collection;
const url = `/${collection}/${post.slug}/`;
const dateStr = new Date(pubDate).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' });

function renderStars(r: number) {
  return '★'.repeat(Math.floor(r)) + '☆'.repeat(5 - Math.floor(r));
}
---
<a href={url} class="post-card" data-tags={tagsJson}>
  {image && (
    <div class="card-img-wrap">
      <img src={image} alt={title} class="card-img" loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <div class="card-meta">
      <span class="card-cat">{catLabel}</span>
      <time datetime={pubDate}>{dateStr}</time>
    </div>
    <h2 class="card-title">{title}</h2>
    {rating && (
      <div class="card-rating">
        <span class="card-stars">{renderStars(rating)}</span>
        <span class="card-rating-val">{rating.toFixed(1)}</span>
      </div>
    )}
    {description && <p class="card-desc">{description}</p>}
  </div>
</a>

<style>
.post-card {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--border);
  border-top: 3px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--bg);
  transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
  color: inherit;
}
.post-card:hover {
  border-top-color: var(--accent);
  border-color: var(--border);
  box-shadow: var(--shadow-sm);
  transform: translateY(-2px);
}

.card-img-wrap { overflow: hidden; }
.card-img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  display: block;
  transition: transform 0.3s;
}
.post-card:hover .card-img { transform: scale(1.03); }

.card-body {
  padding: 18px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 7px;
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  color: var(--text-muted);
}
.card-cat {
  font-family: var(--font-display);
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--accent);
}
.card-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.25;
  color: var(--text);
  transition: color 0.15s;
}
.post-card:hover .card-title { color: var(--accent); }
.card-rating {
  display: flex;
  align-items: center;
  gap: 5px;
}
.card-stars { color: var(--accent); font-size: 0.78rem; letter-spacing: 1px; }
.card-rating-val { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; }
.card-desc {
  font-size: 0.83rem;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}
</style>
