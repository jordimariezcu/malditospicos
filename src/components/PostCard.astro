---
const { post, collection } = Astro.props;
const { title, description, pubDate, rating, image } = post.data;

const categoryLabels: Record<string, string> = {
  gomas: 'Gomas', maderas: 'Maderas', palas: 'Palas', tecnica: 'Técnica',
  guias: 'Guías', jugadores: 'Jugadores', materiales: 'Materiales', recursos: 'Recursos'
};

const catLabel = categoryLabels[collection] || collection;
const catBg = catLabel.toUpperCase();
const url = `/${collection}/${post.slug}/`;
const dateStr = new Date(pubDate).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' });

function renderStars(r: number) {
  const full = Math.floor(r);
  const empty = 5 - full;
  return '★'.repeat(full) + '☆'.repeat(empty);
}
---
<a href={url} class="post-card">
  <!-- Visual top area -->
  <div class="card-visual">
    {image ? (
      <img src={image} alt={title} class="card-img" loading="lazy" />
    ) : (
      <div class="card-editorial">
        <div class="card-editorial-bg" aria-hidden="true">{catBg}</div>
        <div class="card-editorial-cat">{catLabel}</div>
        <div class="card-editorial-title">{title}</div>
      </div>
    )}
  </div>

  <!-- Card body -->
  <div class="card-body">
    <div class="card-meta">
      {!image && <span class="card-category-badge">{catLabel}</span>}
      {image && <span class="card-category-badge">{catLabel}</span>}
      <time datetime={pubDate}>{dateStr}</time>
    </div>
    <h2 class="card-title">{title}</h2>
    {rating && (
      <div class="card-rating" aria-label={`Valoración: ${rating} de 5`}>
        <span class="card-stars">{renderStars(rating)}</span>
        <span class="card-rating-val">{rating.toFixed(1)}</span>
      </div>
    )}
    {description && <p class="card-desc">{description}</p>}
  </div>
</a>

<style>
.post-card {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--bg);
  transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
  text-decoration: none;
  color: inherit;
}
.post-card:hover {
  border-color: var(--accent);
  box-shadow: var(--shadow);
  transform: translateY(-3px);
}

/* Visual area */
.card-visual { position: relative; overflow: hidden; }

/* Image variant */
.card-img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  display: block;
  transition: transform 0.3s;
}
.post-card:hover .card-img { transform: scale(1.03); }

/* Editorial (no-image) variant */
.card-editorial {
  height: 180px;
  background: #1f1f1f;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 16px;
  position: relative;
  overflow: hidden;
}
.card-editorial-bg {
  position: absolute;
  top: -12px;
  right: -8px;
  font-family: var(--font-display);
  font-size: 72px;
  font-weight: 900;
  color: rgba(255,255,255,0.055);
  line-height: 1;
  text-transform: uppercase;
  letter-spacing: -2px;
  text-align: right;
  user-select: none;
  pointer-events: none;
}
.card-editorial-cat {
  font-family: var(--font-display);
  font-size: 9px;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.card-editorial-title {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
}

/* Body */
.card-body {
  padding: 16px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--text-muted);
}
.card-category-badge {
  font-family: var(--font-display);
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  background: var(--accent);
  color: white;
  padding: 3px 7px;
  border-radius: 2px;
}
.card-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.25;
  color: var(--text);
  transition: color 0.15s;
}
.post-card:hover .card-title { color: var(--accent); }
.card-rating {
  display: flex;
  align-items: center;
  gap: 5px;
}
.card-stars { color: var(--accent); font-size: 0.8rem; letter-spacing: 1px; }
.card-rating-val {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-weight: 600;
}
.card-desc {
  font-size: 0.83rem;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}
</style>
