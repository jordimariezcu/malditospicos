---
const { post, collection } = Astro.props;
const { title, description, pubDate, rating } = post.data;
const categoryLabels: Record<string, string> = {
  gomas: 'Gomas', maderas: 'Maderas', palas: 'Palas', tecnica: 'Técnica',
  guias: 'Guías', jugadores: 'Jugadores', materiales: 'Materiales', recursos: 'Recursos'
};
const url = `/${collection}/${post.slug}/`;
const dateStr = new Date(pubDate).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' });

// Star rating rendering
function renderStars(r: number) {
  const full = Math.floor(r);
  const half = (r - full) >= 0.5;
  const empty = 5 - full - (half ? 1 : 0);
  return '★'.repeat(full) + (half ? '½' : '') + '☆'.repeat(empty);
}
---
<article class="post-card">
  <a href={url} class="card-link">
    <span class="card-accent" aria-hidden="true"></span>
    <div class="card-body">
      <div class="card-meta">
        <span class="card-category">{categoryLabels[collection] || collection}</span>
        <time datetime={pubDate}>{dateStr}</time>
      </div>
      <h2 class="card-title">{title}</h2>
      {rating && <div class="card-rating" aria-label={`Valoración: ${rating} de 5`}><span class="stars">{renderStars(rating)}</span><span class="rating-val">{rating}/5</span></div>}
      {description && <p class="card-desc">{description}</p>}
    </div>
    <svg class="card-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
  </a>
</article>

<style>
.post-card {
  position: relative;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--surface);
  overflow: hidden;
  transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
}
.post-card:hover {
  border-color: var(--accent-bright);
  box-shadow: 0 4px 16px rgba(0,47,108,0.10);
  transform: translateY(-1px);
}

/* Left accent bar */
.card-accent {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: var(--border-light);
  transition: background 0.18s;
}
.post-card:hover .card-accent {
  background: var(--accent-bright);
}

.card-link {
  display: flex;
  align-items: flex-start;
  padding: 18px 18px 18px 22px;
  gap: 12px;
}
.card-body { flex: 1; min-width: 0; }

.card-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 7px;
}
.card-category {
  font-family: var(--font-display);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  color: white;
  background: var(--accent);
  padding: 2px 7px;
  border-radius: 2px;
  transition: background 0.15s;
}
.post-card:hover .card-category { background: var(--accent-bright); }
time {
  font-size: 0.76rem;
  color: var(--text-muted);
}
.card-title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 700;
  line-height: 1.25;
  color: var(--text);
  margin-bottom: 5px;
  transition: color 0.15s;
}
.post-card:hover .card-title { color: var(--accent-bright); }
.card-rating {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-bottom: 5px;
}
.stars {
  color: #f59e0b;
  font-size: 0.85rem;
  letter-spacing: 0.05em;
}
.rating-val {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-weight: 500;
}
.card-desc {
  font-size: 0.86rem;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-chevron {
  color: var(--border);
  flex-shrink: 0;
  margin-top: 3px;
  transition: transform 0.15s, color 0.15s;
}
.post-card:hover .card-chevron { transform: translateX(3px); color: var(--accent-bright); }
</style>
