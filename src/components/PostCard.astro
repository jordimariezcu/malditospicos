---
const { post, collection } = Astro.props;
const { title, description, pubDate, category } = post.data;
const categoryLabels: Record<string, string> = {
  gomas: 'Gomas', maderas: 'Maderas', palas: 'Palas', tecnica: 'Técnica',
  guias: 'Guías', jugadores: 'Jugadores', materiales: 'Materiales', recursos: 'Recursos'
};
const url = `/${collection}/${post.slug}/`;
---
<article class="post-card">
  <a href={url} class="card-link">
    <div class="card-body">
      <div class="card-meta">
        <span class="card-category">{categoryLabels[collection] || collection}</span>
        <time datetime={pubDate}>{new Date(pubDate).toLocaleDateString('es-ES', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
      </div>
      <h2 class="card-title">{title}</h2>
      {description && <p class="card-desc">{description}</p>}
    </div>
    <span class="card-arrow">→</span>
  </a>
</article>

<style>
.post-card {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--surface);
  transition: all 0.2s;
  overflow: hidden;
}
.post-card:hover {
  border-color: var(--accent);
  box-shadow: var(--shadow);
  transform: translateY(-2px);
}
.card-link {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20px 24px;
  gap: 16px;
}
.card-body { flex: 1; min-width: 0; }
.card-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
  font-size: 0.78rem;
  color: var(--text-muted);
}
.card-category {
  color: var(--accent-dark);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.card-title {
  font-size: 1.05rem;
  font-weight: 600;
  line-height: 1.3;
  color: var(--text);
  margin-bottom: 6px;
  font-family: var(--font-display);
}
.card-desc {
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-arrow {
  color: var(--text-muted);
  font-size: 1.1rem;
  flex-shrink: 0;
  transition: transform 0.15s, color 0.15s;
  margin-top: 2px;
}
.post-card:hover .card-arrow { transform: translateX(4px); color: var(--accent); }
</style>
