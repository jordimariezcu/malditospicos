---
// MailerLite: sustituye ACCOUNT_ID y FORM_ID con los tuyos
// Los encontrarás en MailerLite → Forms → tu formulario → Embed
const MAILERLITE_ACCOUNT = 'ACCOUNT_ID';
const MAILERLITE_FORM = 'FORM_ID';
const action = `https://assets.mailerlite.com/jsonp/${MAILERLITE_ACCOUNT}/forms/${MAILERLITE_FORM}/subscribe`;

const { compact = false } = Astro.props;
---

<div class:list={['newsletter-wrap', { compact }]}>
  {!compact && (
    <div class="newsletter-header">
      <h2 class="newsletter-title">Análisis directos al correo</h2>
      <p class="newsletter-desc">Nuevas reseñas, comparativas y guías. Sin spam, solo tenis de mesa.</p>
    </div>
  )}
  <form
    class="newsletter-form"
    action={action}
    method="post"
    target="_blank"
    data-newsletter-form
  >
    <div class="form-row">
      <label for="nl-email" class="sr-only">Tu email</label>
      <input
        id="nl-email"
        type="email"
        name="fields[email]"
        placeholder="tu@email.com"
        required
        autocomplete="email"
        class="form-input"
      />
      <button type="submit" class="form-btn">
        Suscribirme
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
    <p class="form-legal">Sin spam. Puedes darte de baja cuando quieras.</p>
  </form>
</div>

<style>
.newsletter-wrap { width: 100%; }

.newsletter-header { margin-bottom: 20px; }
.newsletter-title {
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  color: white;
  margin-bottom: 8px;
}
.newsletter-desc {
  font-size: 0.95rem;
  color: rgba(255,255,255,0.72);
  line-height: 1.5;
  margin: 0;
}

.form-row {
  display: flex;
  gap: 8px;
}
.form-input {
  flex: 1;
  min-width: 0;
  padding: 11px 16px;
  font-family: var(--font-body);
  font-size: 0.95rem;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: var(--radius);
  background: rgba(255,255,255,0.08);
  color: white;
  outline: none;
  transition: border-color 0.15s, background 0.15s;
}
.form-input::placeholder { color: rgba(255,255,255,0.4); }
.form-input:focus { border-color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.12); }

.form-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 11px 20px;
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  background: white;
  color: var(--accent);
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.15s;
  flex-shrink: 0;
}
.form-btn:hover { background: var(--accent-bright); color: white; }
.form-btn svg { transition: transform 0.15s; }
.form-btn:hover svg { transform: translateX(2px); }

.form-legal {
  font-size: 0.74rem;
  color: rgba(255,255,255,0.4);
  margin-top: 8px;
  margin-bottom: 0;
}

/* Compact variant (used in footer etc.) */
.compact .newsletter-title { font-size: 1.15rem; }
.compact .newsletter-desc { font-size: 0.85rem; }

@media (max-width: 480px) {
  .form-row { flex-direction: column; }
  .form-btn { justify-content: center; }
}
</style>
