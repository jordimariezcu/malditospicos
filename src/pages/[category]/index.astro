---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const collections = ['gomas','maderas','palas','tecnica','guias','jugadores','materiales','recursos'] as const;
  const categoryMeta: Record<string, { label: string; description: string; seoTitle?: string; intro?: string }> = {
    gomas: {
      label: 'Gomas',
      seoTitle: 'Gomas de tenis de mesa: reseñas y análisis',
      description: 'Encuentra la goma de tenis de mesa perfecta: lisas, picos cortos, medianos, largos, antispin y antitop. Análisis sin afiliados de todas las marcas.',
      intro: 'Análisis honestos de todos los tipos de gomas de tenis de mesa: <strong>gomas lisas</strong> para velocidad y efecto, <strong>picos cortos</strong> para bloqueo ofensivo, <strong>picos medianos</strong> para control y despiste, <strong>picos largos</strong> para desestabilizar al rival, y <strong>gomas antispin y antitop</strong> para el juego defensivo. Sin afiliados, sin publicidad.',
    },
    maderas: {
      label: 'Maderas',
      seoTitle: 'Maderas de tenis de mesa: guías y análisis',
      description: 'Guía completa de maderas de tenis de mesa: ALL, OFF, OFF+ y DEF. Comparativa de Butterfly, Stiga, Donic, Joola y más para elegir según tu nivel.',
      intro: 'Analizamos todas las categorías de velocidad: <strong>maderas ALL</strong> para control total, <strong>OFF- y OFF</strong> para ofensiva equilibrada, <strong>OFF+</strong> con carbono para máxima velocidad, y <strong>maderas DEF</strong> para el juego defensivo. Comparamos Butterfly, Stiga, Donic, Joola, XIOM, Nittaku y más.',
    },
    palas: { label: 'Configuraciones de Palas', description: 'Configuraciones de palas completas para jugadores profesionales y amateur.' },
    tecnica: { label: 'Técnica', description: 'Saques, golpes, efectos y fundamentos técnicos del tenis de mesa.' },
    guias: { label: 'Guías', description: 'Guías completas para entender el tenis de mesa: materiales, reglas y fundamentos.' },
    jugadores: { label: 'Jugadores', description: 'Perfil y equipamiento de los mejores jugadores de tenis de mesa del mundo.' },
    materiales: { label: 'Materiales', description: 'Todo sobre los materiales de tenis de mesa: gomas especiales, pelotas y accesorios.' },
    recursos: { label: 'Recursos', description: 'Recursos y referencias para mejorar tu tenis de mesa.' },
  };
  return await Promise.all(
    collections.map(async (col) => {
      const posts = await getCollection(col);
      return {
        params: { category: col },
        props: {
          posts: posts.filter((p: any) => !p.data.draft).sort((a: any,b: any) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()),
          collection: col,
          meta: categoryMeta[col]
        }
      };
    })
  );
}
const { posts, collection, meta } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.malditospicos.com" },
    { "@type": "ListItem", "position": 2, "name": meta.label, "item": canonicalURL },
  ],
};
---
<BaseLayout title={meta.seoTitle ?? meta.label} description={meta.description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />
  <div class="cat-page">
    <div class="container">
      <div class="cat-header">
        <a href="/">Inicio</a>
        <span class="cat-header-sep">›</span>
        <span class="cat-header-current">{meta.label}</span>
      </div>
      <h1 class="cat-title">{meta.label}</h1>
      <p class="cat-desc">{meta.description}</p>
      {meta.intro && <p class="cat-intro" set:html={meta.intro} />}
      <div class="posts-count-wrap">
        <span class="posts-count" id="posts-count">{posts.length} artículos</span>
        <span class="tag-filter-badge" id="tag-filter-badge" hidden>
          Filtrando por: <strong id="tag-filter-label"></strong>
          <a href={`/${collection}/`} class="tag-filter-clear" aria-label="Quitar filtro">✕</a>
        </span>
      </div>
      <div class="posts-grid" id="posts-grid">
        {posts.map((post: any) => (
          <PostCard post={post} collection={collection} />
        ))}
      </div>
      <p class="no-results" id="no-results" hidden>No hay artículos con este tag.</p>
    </div>
  </div>
</BaseLayout>

<script>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const tag = params.get('tag');
    if (!tag) return;

    const badge = document.getElementById('tag-filter-badge') as HTMLElement | null;
    const label = document.getElementById('tag-filter-label') as HTMLElement | null;
    const countEl = document.getElementById('posts-count') as HTMLElement | null;
    const grid = document.getElementById('posts-grid') as HTMLElement | null;
    const noResults = document.getElementById('no-results') as HTMLElement | null;

    if (label) label.textContent = tag;
    if (badge) badge.hidden = false;

    const cards = grid ? Array.from(grid.children) as HTMLElement[] : [];
    let visible = 0;
    cards.forEach(card => {
      let cardTags: string[] = [];
      try { cardTags = JSON.parse((card as HTMLElement).dataset.tags ?? '[]'); } catch {}
      const match = cardTags.some((t: string) => t.toLowerCase() === tag.toLowerCase());
      (card as HTMLElement).style.display = match ? '' : 'none';
      if (match) visible++;
    });

    if (countEl) countEl.textContent = `${visible} artículo${visible !== 1 ? 's' : ''}`;
    if (noResults) noResults.hidden = visible > 0;
  })();
</script>

<style>
.cat-page { padding: 48px 0 80px; }
.cat-header {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.82rem;
  color: var(--text-muted);
  margin-bottom: 28px;
}
.cat-header a {
  display: inline-flex;
  align-items: center;
  min-height: 44px;
  padding: 0 4px;
}
.cat-header a:hover { color: var(--accent); }
.cat-header-sep { color: var(--border); }
.cat-header-current {
  display: inline-flex;
  align-items: center;
  min-height: 44px;
  font-family: var(--font-display);
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  background: var(--accent);
  color: white;
  padding: 3px 10px;
  border-radius: 2px;
}
.cat-title {
  font-size: clamp(2rem, 4vw, 3rem);
  letter-spacing: -0.03em;
  margin-bottom: 10px;
  color: var(--text);
}
.cat-desc { font-size: 1rem; color: var(--text-secondary); max-width: 560px; margin-bottom: 8px; }
.cat-intro { font-size: 0.95rem; color: var(--text-secondary); max-width: 700px; margin-bottom: 8px; line-height: 1.65; }
.posts-count-wrap {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 36px;
  padding-bottom: 24px;
  border-bottom: 2px solid var(--text);
}
.posts-count {
  font-size: 0.8rem;
  color: var(--text-muted);
}
.tag-filter-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.8rem;
  background: var(--accent);
  color: white;
  padding: 4px 10px;
  border-radius: 2px;
}
.tag-filter-badge strong { font-weight: 700; }
.tag-filter-clear {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 28px;
  min-height: 28px;
  color: rgba(255,255,255,0.8);
  text-decoration: none;
  font-size: 0.85rem;
  line-height: 1;
  margin-left: 2px;
  border-radius: 2px;
  transition: color 0.15s, background 0.15s;
}
.tag-filter-clear:hover { color: white; background: rgba(255,255,255,0.15); }
.no-results {
  font-size: 0.95rem;
  color: var(--text-muted);
  padding: 40px 0;
}
.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
@media (max-width: 860px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 520px)  { .posts-grid { grid-template-columns: 1fr; } }
</style>
