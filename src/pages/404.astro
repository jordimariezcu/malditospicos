---
import Base from '../layouts/Base.astro';
---
<Base title="Página no encontrada">
  <div class="container-narrow" style="padding: 6rem 1.5rem; text-align: center;">
    <p style="font-size: 4rem; margin-bottom: 1rem;">🏓</p>
    <h1 style="margin-bottom: 1rem;">Página no encontrada</h1>
    <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
      Esta página no existe o ha cambiado de dirección.
    </p>
    <a href="/" style="display: inline-block; background: var(--color-accent); color: white; padding: 0.75rem 1.5rem; border-radius: var(--radius); font-weight: 500;">
      Volver al inicio
    </a>
  </div>
</Base>
