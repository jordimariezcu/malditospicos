---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const collections = ['gomas','maderas','palas','tecnica','guias','jugadores','materiales','recursos'] as const;
const allPosts = (await Promise.all(
  collections.map(async (col) => {
    const posts = await getCollection(col);
    return posts.map(p => ({ ...p, collection: col }));
  })
)).flat().filter(p => !p.data.draft)
  .sort((a,b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const recentPosts = allPosts.slice(0, 9);

const categories = [
  {
    slug: 'gomas', label: 'Gomas', desc: 'Lisas, picos, antispin y más',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="3" x2="12" y2="9"/><line x1="12" y1="15" x2="12" y2="21"/></svg>`
  },
  {
    slug: 'maderas', label: 'Maderas', desc: 'Allround, ofensivas, defensivas',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="11" height="15" rx="3"/><path d="M15 10l5 5-5 5"/></svg>`
  },
  {
    slug: 'palas', label: 'Configuraciones', desc: 'Palas pro y amateur',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="13" height="17" rx="4"/><path d="M16 12l5 5-5 5"/><line x1="3" y1="10" x2="16" y2="10"/></svg>`
  },
  {
    slug: 'tecnica', label: 'Técnica', desc: 'Saques, golpes y efectos',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`
  },
  {
    slug: 'jugadores', label: 'Jugadores', desc: 'Los mejores del mundo',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>`
  },
  {
    slug: 'guias', label: 'Guías', desc: 'Todo lo que necesitas saber',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`
  },
];
---
<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-label">Blog de tenis de mesa</div>
        <h1 class="hero-title">Material, técnica<br/>y mucho más</h1>
        <p class="hero-desc">Guías, reseñas y análisis para jugadores de todos los niveles. Especialistas en gomas de picos.</p>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section-categories">
    <div class="container">
      <div class="categories-grid">
        {categories.map(cat => (
          <a href={`/${cat.slug}/`} class="cat-card">
            <span class="cat-icon" set:html={cat.icon} />
            <div class="cat-text">
              <strong>{cat.label}</strong>
              <span>{cat.desc}</span>
            </div>
            <svg class="cat-arrow" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  <section class="section-posts">
    <div class="container">
      <div class="section-header">
        <h2>Últimas entradas</h2>
      </div>
      <div class="posts-grid">
        {recentPosts.map(post => (
          <PostCard post={post} collection={post.collection} />
        ))}
      </div>
      <div class="view-all-wrap">
        <a href="/archivo/" class="view-all">Ver todos los artículos →</a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section-newsletter">
    <div class="container">
      <div class="newsletter-inner">
        <NewsletterForm />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero {
  padding: 80px 0 64px;
  border-bottom: 3px solid var(--accent);
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-bright) 100%);
  color: white;
}
.hero-inner { max-width: 640px; }
.hero-label {
  font-family: var(--font-display);
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: rgba(255,255,255,0.7);
  font-weight: 600;
  margin-bottom: 16px;
}
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.8rem, 6vw, 5rem);
  font-weight: 800;
  line-height: 1.0;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  margin-bottom: 20px;
  color: white;
}
.hero-desc {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.82);
  line-height: 1.6;
  max-width: 480px;
  font-weight: 300;
}

/* Categories */
.section-categories { padding: 48px 0; border-bottom: 1px solid var(--border); }
.categories-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 10px;
}
.cat-card {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 18px;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--surface);
  transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
}
.cat-card:hover {
  border-color: var(--accent-bright);
  box-shadow: var(--shadow-sm);
  transform: translateY(-1px);
}
.cat-icon {
  width: 40px;
  height: 40px;
  background: var(--accent-bg);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
  flex-shrink: 0;
  transition: background 0.18s, color 0.18s;
}
.cat-card:hover .cat-icon { background: var(--accent); color: white; }
.cat-text { flex: 1; }
.cat-text strong {
  display: block;
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--text);
}
.cat-text span { font-size: 0.8rem; color: var(--text-muted); }
.cat-arrow {
  color: var(--border);
  transition: transform 0.15s, color 0.15s;
  flex-shrink: 0;
}
.cat-card:hover .cat-arrow { transform: translateX(3px); color: var(--accent-bright); }

/* Posts */
.section-posts { padding: 56px 0 64px; }
.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 28px;
  padding-bottom: 16px;
  border-bottom: 3px solid var(--accent);
}
.section-header h2 { font-size: 1.6rem; color: var(--accent); }
.posts-grid { display: grid; gap: 10px; }
.view-all-wrap { margin-top: 32px; text-align: center; }
.view-all {
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: white;
  background: var(--accent);
  padding: 12px 32px;
  border-radius: var(--radius);
  transition: all 0.15s;
  border: 2px solid var(--accent);
}
.view-all:hover { background: var(--accent-bright); border-color: var(--accent-bright); }

/* Newsletter */
.section-newsletter {
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-bright) 100%);
  border-top: 3px solid var(--accent-dark);
}
.newsletter-inner {
  padding: 56px 0;
  max-width: 560px;
}
</style>
