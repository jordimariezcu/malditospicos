---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const collections = ['gomas','maderas','palas','tecnica','guias','jugadores','materiales','recursos'] as const;
const allPosts = (await Promise.all(
  collections.map(async (col) => {
    const posts = await getCollection(col);
    return posts.map(p => ({ ...p, collection: col }));
  })
)).flat().filter(p => !p.data.draft)
  .sort((a,b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const recentPosts = allPosts.slice(0, 9);

const categoryLabels: Record<string, string> = {
  gomas: 'Gomas', maderas: 'Maderas', palas: 'Palas', tecnica: 'Técnica',
  guias: 'Guías', jugadores: 'Jugadores', materiales: 'Materiales', recursos: 'Recursos'
};

const categories = [
  { slug: 'gomas',      label: 'Gomas'     },
  { slug: 'maderas',    label: 'Maderas'   },
  { slug: 'palas',      label: 'Palas'     },
  { slug: 'tecnica',    label: 'Técnica'   },
  { slug: 'jugadores',  label: 'Jugadores' },
  { slug: 'guias',      label: 'Guías'     },
  { slug: 'materiales', label: 'Materiales'},
];
---
<BaseLayout>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="container">
      <div class="hero-label">El único blog editorial de tenis de mesa en español</div>
      <h1 class="hero-title">Material, técnica<br/>y <span>mucho más</span></h1>
      <p class="hero-subtitle">Reviews honestas de gomas, maderas y accesorios. Sin tiendas, sin afiliados. Solo opinión de quien juega.</p>
      <a href="/archivo/" class="btn-primary">Ver todos los artículos</a>
    </div>
  </section>

  <!-- ── CATEGORIES BAR ── -->
  <nav class="categories-bar" aria-label="Categorías">
    {categories.map(cat => (
      <a href={`/${cat.slug}/`} class="cat-item">{cat.label}</a>
    ))}
  </nav>

  <!-- ── ARTICLES ── -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Últimos <span>artículos</span></h2>
        <a href="/archivo/" class="section-link">Ver todos →</a>
      </div>
      <div class="posts-grid">
        {recentPosts.map(post => (
          <PostCard post={post} collection={post.collection} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── PHILOSOPHY ── -->
  <div class="philosophy">
    <div class="container">
      <div class="philosophy-inner">
        <p class="philosophy-text">En Malditospicos nos sentimos más cómodos con <strong>las marcas que se toman en serio lo que fabrican</strong>. Las que trabajan con tradición, con detalle, con cariño. Las que en los grandes medios en español casi no aparecen. Eso es lo que cubrimos aquí.</p>
        <a href="/sobre-nosotros/" class="philosophy-link">Sobre el proyecto →</a>
      </div>
    </div>
  </div>

  <!-- ── BRANDS ── -->
  <div class="brands-strip">
    <div class="container">
      <div class="brands-inner">
        <span class="brands-label">Seguimos de cerca</span>
        <div class="brands-list">
          <span>Nittaku</span>
          <span>Yasaka</span>
          <span>Victas</span>
          <span>Dr. Neubauer</span>
          <span>Tibhar</span>
          <span>Andro</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── NEWSLETTER ── -->
  <section class="section-newsletter" id="newsletter">
    <div class="container">
      <div class="newsletter-inner">
        <NewsletterForm />
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── HERO ── */
.hero {
  padding: 80px 0 72px;
  border-bottom: 1px solid var(--border);
}
.hero-label {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.hero-label::before {
  content: '';
  display: inline-block;
  width: 24px;
  height: 2px;
  background: var(--accent);
  border-radius: 2px;
  flex-shrink: 0;
}
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.8rem, 6vw, 5rem);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.03em;
  color: var(--text);
  margin-bottom: 20px;
  text-transform: uppercase;
}
.hero-title span { color: var(--accent); }
.hero-subtitle {
  font-size: 1.05rem;
  color: var(--text-secondary);
  line-height: 1.65;
  max-width: 520px;
  margin-bottom: 32px;
  font-weight: 300;
}
.btn-primary {
  display: inline-block;
  background: var(--text);
  color: #fff;
  padding: 13px 28px;
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  border-radius: var(--radius);
  transition: background 0.15s;
}
.btn-primary:hover { background: #000; }

/* ── CATEGORIES BAR ── */
.categories-bar {
  display: flex;
  border-bottom: 2px solid var(--text);
  border-top: 2px solid var(--text);
  overflow-x: auto;
  scrollbar-width: none;
}
.categories-bar::-webkit-scrollbar { display: none; }
.cat-item {
  flex: 1;
  min-width: fit-content;
  padding: 13px 18px;
  text-align: center;
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text);
  border-right: 1px solid var(--border);
  transition: background 0.15s, color 0.15s;
  white-space: nowrap;
}
.cat-item:last-child { border-right: none; }
.cat-item:hover { background: var(--accent); color: #fff; }

/* ── SECTION ── */
.section { padding: 56px 0; }
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 28px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
  position: relative;
}
.section-header::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 40px;
  height: 2px;
  background: var(--accent);
}
.section-title {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 900;
  color: var(--text);
  text-transform: none;
  letter-spacing: -0.02em;
}
.section-title span { color: var(--accent); }
.section-link {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--accent);
  transition: color 0.15s;
}
.section-link:hover { color: var(--accent-dark); }

.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ── PHILOSOPHY ── */
.philosophy {
  background: var(--bg-secondary);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 48px 0;
}
.philosophy-inner {
  max-width: 680px;
  border-left: 3px solid var(--accent);
  padding-left: 28px;
}
.philosophy-text {
  font-size: 1.1rem;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 16px;
}
.philosophy-text strong { color: var(--text); font-weight: 700; }
.philosophy-link {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--accent);
  transition: color 0.15s;
}
.philosophy-link:hover { color: var(--accent-dark); }

/* ── BRANDS ── */
.brands-strip {
  padding: 24px 0;
  border-bottom: 1px solid var(--border);
}
.brands-inner {
  display: flex;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}
.brands-label {
  font-family: var(--font-display);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-muted);
  white-space: nowrap;
  flex-shrink: 0;
}
.brands-list {
  display: flex;
  gap: 28px;
  flex-wrap: wrap;
  align-items: center;
}
.brands-list span {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--border);
}

/* ── NEWSLETTER ── */
.section-newsletter {
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-bright) 100%);
  border-top: 3px solid var(--accent-dark);
}
.newsletter-inner {
  padding: 56px 0;
  max-width: 560px;
}

/* ── RESPONSIVE ── */
@media (max-width: 860px) {
  .posts-grid { grid-template-columns: repeat(2, 1fr); }
  .hero { padding: 56px 0 48px; }
}
@media (max-width: 560px) {
  .posts-grid { grid-template-columns: 1fr; }
  .hero-title { font-size: 2.4rem; }
  .brands-inner { gap: 16px; }
  .section { padding: 40px 0; }
  .philosophy { padding: 36px 0; }
  .philosophy-inner { padding-left: 20px; }
  .newsletter-inner { padding: 40px 0; }
}
</style>
